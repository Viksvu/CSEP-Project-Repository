<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.scenes.ShoppingListCtrl">

    <top>
        <ToolBar>
            <Label text="Shopping List" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button onAction="#goBack" text="Back" />
        </ToolBar>
    </top>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10;">
            <Label fx:id="totalItemsLabel" text="Total: 0 items" />
         <Button mnemonicParsing="false" onAction="#addRecipe" text="Add recipe" />
         <Button mnemonicParsing="false" onAction="#addIngredient" prefHeight="27.0" prefWidth="121.0" text="Add ingredient" />
            <Button onAction="#clearList" text="Clear list" />
        </HBox>
    </bottom>
   <center>
      <AnchorPane fx:id="ingredientsPane" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <ListView fx:id="shoppingListView" fixedCellSize="24.7" layoutX="7.0" prefHeight="308.0" prefWidth="591.0" />
         </children>
      </AnchorPane>
   </center>

</BorderPane>
