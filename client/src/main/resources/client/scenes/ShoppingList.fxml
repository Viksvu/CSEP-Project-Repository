<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.scenes.ShoppingListCtrl">
   <children>
      <BorderPane prefHeight="400.0" prefWidth="600.0">
      
          <top>
              <ToolBar>
                  <Label fx:id="shoppingListLabel" text="%shoppingList.label" />
                  <Pane HBox.hgrow="ALWAYS">
                  <children>
                     <Button fx:id="downloadShoppingListButton" layoutX="14.0" mnemonicParsing="false" onAction="#downloadShoppingList" />
                  </children></Pane>
                  <Button fx:id="shoppingListBackButton" onAction="#goBack" text="%shoppingList.back" />
              </ToolBar>
          </top>
      
          <bottom>
              <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10;">
                  <Label fx:id="totalItemsLabel" text="Total: 0 items" />
               <Button fx:id="shoppingListAddRecipeButton" mnemonicParsing="false" onAction="#addRecipe" text="%shoppingList.addRecipe" />
               <Button fx:id="shoppingListAddIngredients" mnemonicParsing="false" onAction="#addIngredient" prefHeight="27.0" prefWidth="121.0" text="%shoppingList.addIngredient" />
                  <Button fx:id="shoppingListClearButton" onAction="#clearList" text="%shoppingList.clear" />
              </HBox>
          </bottom>
         <center>
            <ScrollPane BorderPane.alignment="CENTER">
               <content>
                  <AnchorPane fx:id="ingredientsPane" prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <ListView fx:id="shoppingListView" fixedCellSize="24.7" layoutX="7.0" prefHeight="308.0" prefWidth="591.0" />
                     </children>
                  </AnchorPane>
               </content>
            </ScrollPane>
         </center>
      
      </BorderPane>
   </children>
</StackPane>
